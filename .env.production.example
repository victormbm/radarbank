# Copie para .env.production e preencha os valores

# Database (Neon, Supabase, ou Railway)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT Secret (gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET="SUA_CHAVE_SUPER_SECRETA_AQUI_MINIMO_32_CARACTERES"

# App URL
NEXT_PUBLIC_APP_URL="https://seu-app.vercel.app"

# Opcional: Analytics
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
