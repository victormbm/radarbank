# ─── Copie para .env.production e preencha os valores ───────────────────────
# Em produção no GCP, prefira injetar via Secret Manager (cloudbuild.yaml já
# está configurado para isso). Este arquivo serve como referência.

# ─── Banco de Dados ────────────────────────────────────────────────────────
# GCP Cloud SQL (PostgreSQL) ou Neon/Supabase:
DATABASE_URL="postgresql://user:password@host:5432/radarbank?sslmode=require"

# ─── Auth ──────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET="SUA_CHAVE_SUPER_SECRETA_AQUI_MINIMO_32_CARACTERES"

CRON_SECRET="SUA_CHAVE_CRON_SECRETA"

# ─── App ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seudominio.com.br"

# ─── Rate Limit Distribuído (Upstash Redis) ────────────────────────────────
# Crie em https://console.upstash.com → Redis → Create Database (Free tier OK)
# Copie os valores de "REST API" na interface do Upstash.
UPSTASH_REDIS_REST_URL="https://XXXX.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXxx="

# ─── GCP Cloud Run (referência — normalmente injetado pelo cloudbuild.yaml) ──
# _REGION:   southamerica-east1
# _REPO:     radar-bank       (Artifact Registry)
# _SERVICE:  radar-bank       (nome do Cloud Run service)
# _APP_URL:  https://seudominio.com.br

# ─── Opcional: Analytics ───────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
