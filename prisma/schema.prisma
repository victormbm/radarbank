generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Bank {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  cnpj      String?     @unique
  type      String
  country   String
  segment   String?     // S1, S2, S3, S4, S5 (classificação BCB)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  metricValues MetricValue[]
  scores    BankScore[]
  snapshots BankSnapshot[]

  @@map("banks")
}

model Metric {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  unit        String
  category    String   // capital, liquidity, profitability, credit, size, growth
  description String?
  values      MetricValue[]

  @@map("metrics")
}

model MetricValue {
  id       String   @id @default(cuid())
  bankId   String
  metricId String
  date     DateTime
  value    Float
  bank     Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  metric   Metric   @relation(fields: [metricId], references: [id], onDelete: Cascade)

  @@index([bankId])
  @@index([metricId])
  @@index([date])
  @@map("metric_values")
}

model BankScore {
  id                 String   @id @default(cuid())
  bankId             String
  date               DateTime
  status             String   // healthy, warning, critical
  totalScore         Float
  capitalScore       Float
  liquidityScore     Float
  profitabilityScore Float
  creditScore        Float
  bank               Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@index([bankId])
  @@index([date])
  @@index([status])
  @@map("bank_scores")
}

model BankSnapshot {
  id                String   @id @default(cuid())
  bankId            String
  date              DateTime
  
  // Capital (Basileia)
  basilRatio        Float?   // Índice de Basileia
  tier1Ratio        Float?   // Capital Principal
  cet1Ratio         Float?   // Common Equity Tier 1
  leverageRatio     Float?   // Alavancagem
  
  // Liquidez
  lcr               Float?   // Liquidity Coverage Ratio
  nsfr              Float?   // Net Stable Funding Ratio
  quickLiquidity    Float?   // Liquidez Imediata
  loanToDeposit     Float?   // Relação Empréstimos/Depósitos
  
  // Rentabilidade
  roe               Float?   // Return on Equity
  roa               Float?   // Return on Assets
  nim               Float?   // Net Interest Margin
  costToIncome      Float?   // Eficiência Operacional
  
  // Qualidade de Crédito
  nplRatio          Float?   // Inadimplência
  coverageRatio     Float?   // Taxa de Cobertura
  writeOffRate      Float?   // Taxa de Baixa
  creditQuality     Float?   // Índice de Qualidade
  
  // Tamanho (em milhões)
  totalAssets       Float?   // Ativos Totais
  equity            Float?   // Patrimônio Líquido
  totalDeposits     Float?   // Depósitos Totais
  loanPortfolio     Float?   // Carteira de Crédito
  
  // Crescimento (%)
  assetGrowth       Float?   // Crescimento de Ativos YoY
  loanGrowth        Float?   // Crescimento de Empréstimos YoY
  depositGrowth     Float?   // Crescimento de Depósitos YoY
  
  bank              Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  
  @@unique([bankId, date])
  @@index([bankId])
  @@index([date])
  @@map("bank_snapshots")
}

model DataIngestionLog {
  id            String   @id @default(cuid())
  source        String   // bcb, cvm, manual
  status        String   // success, error, partial
  recordsCount  Int
  errorMessage  String?  @db.Text
  metadata      String?  @db.Text
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  
  @@index([source])
  @@index([status])
  @@index([startedAt])
  @@map("data_ingestion_logs")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String   // Hash bcrypt (nunca texto puro)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
  @@index([email])
}
